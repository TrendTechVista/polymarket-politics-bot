# Strategy: value | arbitrage
POLITICS_STRATEGY=value
# Gamma tag_id for politics (GET https://gamma-api.polymarket.com/tags). Empty = all active events
POLITICS_TAG_ID=
POLITICS_POLL_INTERVAL_MS=60000
POLITICS_EVENTS_LIMIT=50

POLITICS_VALUE_MIN_EDGE=0.02
# POLITICS_VALUE_FAIR_PROB=0.5
POLITICS_MAX_ORDER_USD=0
POLITICS_STAKE_USD=10

POLITICS_ARB_MIN_PROFIT=0.01

POLITICS_DRY_RUN=true

POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...
